{
    "name": "markdown-editor",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=10.0.0"
    },
    "scripts": {
        "dev": "rsbuild dev",
        "build": "tsc && rsbuild build && node scripts/generate-sw.mjs",
        "test:watch": "vitest",
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "coverage:ui": "vitest --coverage --ui",
        "typecheck": "tsc --noEmit",
        "lint": "biome check .",
        "format": "biome check --write .",
        "preview": "rsbuild preview",
        "prepare": "husky install"
    },
    "dependencies": {
        "idb-keyval": "^6.2.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-remark": "^2.1.0",
        "zustand": "^5.0.12"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@biomejs/biome",
            "@parcel/watcher",
            "core-js",
            "esbuild"
        ]
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@rsbuild/core": "^1.3.0",
        "@rsbuild/plugin-react": "^1.3.0",
        "@rsbuild/plugin-sass": "^1.5.1",
        "@rsbuild/plugin-svgr": "^1.3.0",
        "@testing-library/jest-dom": "^6.2.0",
        "@testing-library/react": "^14.1.2",
        "@testing-library/user-event": "^14.5.2",
        "@types/react": "^18.2.47",
        "@types/react-dom": "^18.2.18",
        "@vitest/coverage-v8": "^1.1.3",
        "@vitest/ui": "^1.1.3",
        "autoprefixer": "^10.4.16",
        "happy-dom": "^20.8.9",
        "husky": "^8.0.3",
        "postcss": "^8.4.33",
        "sass": "^1.69.7",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vitest": "^1.1.3",
        "workbox-build": "^7.4.0"
    }
}
