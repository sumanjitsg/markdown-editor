{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "organizeImports": { "enabled": true },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "arrowParentheses": "asNeeded"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "files": {
        "ignoreUnknown": false,
        "ignore": ["dist", "__tests__/coverage", "node_modules"]
    },
    "overrides": [
        {
            "include": ["**/__tests__/**", "**/*.test.tsx"],
            "linter": {
                "rules": {
                    "complexity": {
                        "noUselessFragments": "off"
                    }
                }
            }
        }
    ]
}
